{
  "realm": "hypercache",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 7200,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "read",
        "description": "Read access to the cache. Maps into the cache_scopes claim, which the cache's OIDC verifier reads."
      },
      {
        "name": "write",
        "description": "Write access. Maps into cache_scopes."
      },
      {
        "name": "admin",
        "description": "Admin access (eviction controls). Maps into cache_scopes."
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@hypercache.local",
      "firstName": "Admin",
      "lastName": "User",
      "emailVerified": true,
      "enabled": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "read",
        "write",
        "admin"
      ]
    },
    {
      "username": "ops",
      "email": "ops@hypercache.local",
      "firstName": "Ops",
      "lastName": "User",
      "emailVerified": true,
      "enabled": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "ops",
          "temporary": false
        }
      ],
      "realmRoles": [
        "read",
        "write"
      ]
    },
    {
      "username": "viewer",
      "email": "viewer@hypercache.local",
      "firstName": "Viewer",
      "lastName": "User",
      "emailVerified": true,
      "enabled": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": [
        "read"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "hypercache-monitor",
      "name": "HyperCache Monitor",
      "description": "Confidential OAuth2 client used by the HyperCache Monitor's auth.js v5 OIDC flow.",
      "enabled": true,
      "publicClient": false,
      "secret": "hypercache-monitor-dev-secret",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/api/auth/callback/oidc",
        "http://localhost:3000/api/auth/oidc-callback"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "email",
        "cache-scopes"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/login"
      }
    }
  ],
  "clientScopes": [
    {
      "name": "profile",
      "description": "OIDC built-in profile scope. Defined here because realm-import doesn't auto-create Keycloak's standard scopes — without this, auth.js's `scope=openid profile email` request fails Keycloak's scope-validation gate.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "email",
      "description": "OIDC built-in email scope. Same reason as `profile` above.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "web-origins",
      "description": "Standard scope that emits CORS allowed-origin claims. Keep this on the default scope list so auth.js's CORS-aware client behaves identically to a stock Keycloak realm.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "cache-scopes",
      "description": "Emits the user's realm roles into cache_scopes plus adds hypercache-monitor to the access-token aud claim.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-cache-scopes",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "cache_scopes",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "usermodel.realmRoleMapping.rolePrefix": ""
          }
        },
        {
          "name": "audience-cache-monitor",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "hypercache-monitor",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ]
}
