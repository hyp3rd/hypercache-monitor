{
  "plugins": ["prettier-plugin-tailwindcss", "@trivago/prettier-plugin-sort-imports"],
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 110,
  "tabWidth": 2,
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "importOrder": ["^react", "^react-native", "^[a-zA-Z]", "^@?\\w", "^[./]"]
}
